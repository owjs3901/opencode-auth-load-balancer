{
  "name": "opencode-auth-load-balancer",
  "version": "0.2.1",
  "description": "Load-balance opencode requests across multiple Anthropic (Claude) and OpenAI (Codex) OAuth accounts, weighted primarily by weekly usage with drain-before-reset scheduling.",
  "type": "module",
  "license": "MIT",
  "author": "owjs3901",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owjs3901/opencode-auth-load-balancer.git"
  },
  "homepage": "https://github.com/owjs3901/opencode-auth-load-balancer#readme",
  "bugs": {
    "url": "https://github.com/owjs3901/opencode-auth-load-balancer/issues"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "tui"
  ],
  "scripts": {
    "sync:tui": "bun -e \"await Bun.write('tui/auth-load-balancer-scoring.ts', Bun.file('src/scheduler/score-core.ts'))\"",
    "build": "bun run sync:tui && bun build ./src/index.ts --outdir dist --target node --format esm && tsc -p tsconfig.build.json",
    "dev": "bun build ./src/index.ts --outdir dist --target node --format esm --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tui.json --noEmit",
    "typecheck:tui": "tsc -p tsconfig.tui.json --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "status": "bun run src/cli/status.ts",
    "changepacks": "bunx @changepacks/cli",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.13"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.13",
    "@opentui/core": "0.4.2",
    "@opentui/solid": "0.4.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "eslint-plugin-devup": "^2.0.19",
    "husky": "^9.1",
    "oxlint": "1.72",
    "solid-js": "1.9.14",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "anthropic",
    "claude",
    "openai",
    "codex",
    "oauth",
    "load-balancer"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
