{
  "name": "opencode-auth-load-balancer",
  "version": "0.1.0",
  "description": "Load-balance opencode requests across multiple Anthropic (Claude) and OpenAI (Codex) OAuth accounts, weighted primarily by weekly usage with drain-before-reset scheduling.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "tui"
  ],
  "scripts": {
    "sync:tui": "bun -e \"await Bun.write('tui/auth-load-balancer-scoring.ts', Bun.file('src/scheduler/score-core.ts'))\"",
    "build": "bun run sync:tui && bun build ./src/index.ts --outdir dist --target node --format esm && tsc -p tsconfig.build.json",
    "dev": "bun build ./src/index.ts --outdir dist --target node --format esm --watch",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.tui.json --noEmit",
    "typecheck:tui": "tsc -p tsconfig.tui.json --noEmit",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "status": "bun run src/cli/status.ts",
    "prepare": "husky"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.17.9"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.17.9",
    "@opentui/core": "0.3.4",
    "@opentui/keymap": "0.3.4",
    "@opentui/solid": "0.3.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.0.0",
    "eslint-plugin-devup": "^2.0.19",
    "husky": "^9.1",
    "oxlint": "1.64",
    "solid-js": "1.9.12",
    "typescript": "^6.0.3"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "anthropic",
    "claude",
    "openai",
    "codex",
    "oauth",
    "load-balancer"
  ]
}
